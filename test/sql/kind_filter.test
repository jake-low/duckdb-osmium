# name: test/sql/kind_filter.test
# description: kind filter pushdown, dual emission of closed ways, area=yes/no semantics
# group: [sql]

require osmium

# Kind filter pushdown

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'node';
----
317

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'line';
----
304

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'area';
----
77

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'relation';
----
13

# kind IN (...)
query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind IN ('node', 'relation');
----
330

query TI
SELECT kind, count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind IN ('node', 'relation') GROUP BY kind ORDER BY kind;
----
node	317
relation	13

# kind IN with three values
query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind IN ('node', 'line', 'area');
----
698

# kind OR (equivalent to kind IN)
query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'node' OR kind = 'area';
----
394

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'node' OR kind = 'line';
----
621

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'line' OR kind = 'relation';
----
317

# kind OR combined with tag predicate
query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE (kind = 'node' OR kind = 'area') AND tags['name'] IS NOT NULL;
----
72

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE (kind = 'node' OR kind = 'line') AND tags['highway'] IS NOT NULL;
----
232

# Closed ways without area=yes/no are emitted as both line and area

query TTI
SELECT kind, type, id FROM osmium_read('test/data/bainbridge.osm') WHERE id = 52384079 ORDER BY kind;
----
area	way	52384079
line	way	52384079

query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind IN ('line', 'area');
----
381

# area=yes / area=no semantics

query TI
SELECT kind, id FROM osmium_read('test/data/bainbridge.osm') WHERE id = 1456812001 ORDER BY kind;
----
area	1456812001

query TI
SELECT kind, id FROM osmium_read('test/data/bainbridge.osm') WHERE id = 1270809431 ORDER BY kind;
----
area	1270809431

query TI
SELECT kind, id FROM osmium_read('test/data/bainbridge.osm') WHERE id = 1066832669 ORDER BY kind;
----
line	1066832669

query TI
SELECT kind, id FROM osmium_read('test/data/bainbridge.osm') WHERE id = 448047207 ORDER BY kind;
----
line	448047207

# impossible predicate (should match zero rows)
query I
SELECT count(*) FROM osmium_read('test/data/bainbridge.osm') WHERE kind = 'node' AND kind = 'area';
----
0
